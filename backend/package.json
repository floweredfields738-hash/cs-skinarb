{
  "name": "cs-skin-intelligence-backend",
  "version": "1.0.0",
  "description": "Bloomberg Terminal for CS:GO Skins - Backend API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "npx tsx src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "market:sync": "node scripts/market-sync/market-data-sync.js",
    "score:calculate": "node scripts/data-processors/calculate-scores.js",
    "arbitrage:detect": "node scripts/data-processors/detect-arbitrage.js",
    "predict:prices": "node scripts/data-processors/predict-prices.js"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.5",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-jwt": "^8.4.1",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "node-telegram-bot-api": "^0.67.0",
    "otplib": "^13.3.0",
    "passport": "^0.7.0",
    "passport-steam": "^1.0.14",
    "pg": "^8.11.2",
    "qrcode": "^1.5.4",
    "redis": "^4.6.10",
    "resend": "^6.9.4",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.1",
    "tsx": "^4.7.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@simplewebauthn/types": "^12.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/passport": "^1.0.17",
    "@types/passport-steam": "^1.0.6",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
