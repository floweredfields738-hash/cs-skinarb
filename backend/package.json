{
  "name": "cs-skin-intelligence-backend",
  "version": "1.0.0",
  "description": "Bloomberg Terminal for CS:GO Skins - Backend API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "market:sync": "node scripts/market-sync/market-data-sync.js",
    "score:calculate": "node scripts/data-processors/calculate-scores.js",
    "arbitrage:detect": "node scripts/data-processors/detect-arbitrage.js",
    "predict:prices": "node scripts/data-processors/predict-prices.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-jwt": "^8.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.2",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "bull": "^4.11.5",
    "axios": "^1.6.2",
    "passport": "^0.7.0",
    "passport-steam": "^1.0.14",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
