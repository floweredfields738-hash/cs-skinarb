NODE_ENV=development
PORT=5000

# ─── Supabase PostgreSQL (free tier) ─────────────────
# Get these from: Supabase Dashboard → Project Settings → Database
DB_HOST=db.XXXXXXXXXXXX.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
DB_NAME=postgres
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.XXXXXXXXXXXX.supabase.co:5432/postgres

# ─── Redis (Upstash free tier) ───────────────────────
# Supabase doesn't include Redis, so use Upstash (free):
# Sign up at https://upstash.com → Create Redis database → Copy details
# OR set these to empty and the app will run without Redis cache (slower but works)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=

# ─── Auth & Security ────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-secret-change-in-production
SESSION_SECRET=session-secret-key

# ─── Steam Auth ─────────────────────────────────────
STEAM_API_KEY=
STEAM_REALM=http://localhost:5000
STEAM_RETURN_URL=http://localhost:5000/api/auth/steam/return
FRONTEND_URL=http://localhost:3000

# ─── Market Data ────────────────────────────────────
MARKET_SYNC_INTERVAL=300000
USE_REAL_DATA=true
SKINPORT_API_KEY=
CSFLOAT_API_KEY=
PRICEMPIRE_API_KEY=

# ─── Frontend ───────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
