# Database Configuration
DB_USER=csadmin
DB_PASSWORD=secure_password
DB_NAME=cs_skin_platform

# Backend Configuration
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://csadmin:secure_password@localhost:5432/cs_skin_platform

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-secret-change-in-production

# Steam OAuth Configuration
STEAM_API_KEY=your-steam-api-key-here
STEAM_REALM=http://localhost:5000
STEAM_RETURN_URL=http://localhost:5000/api/auth/steam/return

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:5000/api

# Session Configuration
SESSION_SECRET=session-secret-key

# Data Sync Configuration
MARKET_SYNC_INTERVAL=300000
DATA_PROCESSING_INTERVAL=600000

# Logging
LOG_LEVEL=debug
